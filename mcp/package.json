  },
  "dependencies": {
    "@medplum/fhirtypes": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.21.1",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
