{
  "name": "osod-mcp",
  "version": "0.1.0",
  "description": "OSOD MCP server — exposes Medplum FHIR tools to Claude / Iris / any MCP client",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "bin": {
    "osod-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
