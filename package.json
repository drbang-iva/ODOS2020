{
  "name": "osod",
  "version": "0.0.1",
  "description": "Open Source Optometry — practitioner-owned EHR on Medplum FHIR foundation",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "bin": {
    "osod": "./scripts/osod.ts"
  },
  "scripts": {
    "up": "docker-compose up -d",
    "down": "docker-compose down",
    "reset": "docker-compose down -v",
    "logs": "docker-compose logs -f medplum-server",
    "poc": "tsx src/index.ts",
    "install-profiles": "tsx scripts/install-profiles.ts",
    "setup-practice": "tsx scripts/setup-practice.ts",
    "preflight": "tsx scripts/preflight-lint.ts",
    "dr-drill": "tsx scripts/dr-drill.ts",
    "audit-verify": "tsx scripts/verify-tier1-visit-audit.ts",
    "agentops:migration-type-regen": "tsx scripts/agentops-migration-type-regen.ts",
    "verify-backup-destination": "tsx scripts/verify-backup-destination.ts"
  },
  "dependencies": {
    "@medplum/fhirtypes": "^4.0.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
