# OSOD — local dev environment
# Copy to .env and fill in. Never commit .env (it's in .gitignore).

# Medplum server (set via medplum.config.json for dev; here for dev scripts)
MEDPLUM_BASE_URL=http://localhost:8103
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# Practice setup wizard — human-provisioned credentials
OSOD_PRACTICE_NAME="OSOD Local Practice"
OSOD_ADMIN_EMAIL=admin@osod.local
OSOD_ADMIN_NAME="OSOD Admin"
OSOD_ADMIN_PASSWORD=
OSOD_SETUP_INTERACTIVE_ACK=

# Backward-compatible aliases used by older dev scripts
MEDPLUM_ADMIN_EMAIL=admin@osod.local
MEDPLUM_ADMIN_PASSWORD=
OSOD_POSTGRES_URL=postgresql://medplum:medplum@127.0.0.1:5432/medplum
OSOD_BACKUP_DIR=./backup

# AMA CPT API — token from https://platform.ama-assn.org/ama/ dev portal
# Not used yet; loader comes post-Chacon call
AMA_CPT_API_TOKEN=
